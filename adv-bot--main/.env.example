# Copy this file to .env for local development.
# On Railway, set these as Variables in the service settings instead —
# do NOT commit a real .env file to git.

# Required: your Discord bot token (Discord Developer Portal > Bot > Reset Token)
TOKEN=

# Optional: powers the AI chat/AI-command features (https://console.groq.com/keys)
GROQ_API_KEY=

# Optional: powers image search commands (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Optional: powers GIF/meme commands (https://developers.giphy.com/)
GIPHY_API_KEY=

# Optional: powers Spotify song lookups in the music commands (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: powers the /map command's static map images (https://developer.mapquest.com/)
MAPQUEST_API_KEY=

# Optional: channel IDs for the guild-join/leave log and the live server/user count
# channel-name stats. Leave unset to disable these features - they safely do nothing
# if not configured.
LOG_CHANNEL_ID=
SERVER_COUNT_CHANNEL_ID=
USER_COUNT_CHANNEL_ID=
